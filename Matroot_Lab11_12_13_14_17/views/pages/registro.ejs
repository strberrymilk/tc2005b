<%- include('../includes/head') %>

<body>
    <div class="min-h-screen flex items-center justify-center py-8" style="background-image: url('/images/login_background.jpg'); background-size: cover; background-position: center;">
        <div class="hero-overlay bg-opacity-0 min-h-screen absolute inset-0"></div>
        <div class="card bg-base-100 w-full max-w-lg shadow-xl z-10 mx-4">
            <div class="card-body">
                <h2 class="card-title text-2xl mb-2">Registrarse</h2>
                <form action="/login/registro" method="POST">
                    <!-- Username -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Nombre de usuario</span>
                        </label>
                        <input type="text" name="username" placeholder="usuario123" class="input input-bordered" required />
                    </div>
                    
                    <!-- Email -->
                    <div class="form-control mt-3">
                        <label class="label">
                            <span class="label-text">Correo electrónico</span>
                        </label>
                        <input type="email" name="email" placeholder="correo@ejemplo.com" class="input input-bordered" required />
                    </div>
                    
                    <!-- Password -->
                    <div class="form-control mt-3">
                        <label class="label">
                            <span class="label-text">Contraseña</span>
                        </label>
                        <input type="password" name="password" placeholder="Tu contraseña" class="input input-bordered" required minlength="6" />
                    </div>
                    
                    <!-- Name -->
                    <div class="form-control mt-3">
                        <label class="label">
                            <span class="label-text">Nombre(s)</span>
                        </label>
                        <input type="text" name="name" placeholder="Juan" class="input input-bordered" required />
                    </div>
                    
                    <!-- Lastname 1 -->
                    <div class="form-control mt-3">
                        <label class="label">
                            <span class="label-text">Apellido paterno</span>
                        </label>
                        <input type="text" name="lastname_1" placeholder="Pérez" class="input input-bordered" required />
                    </div>
                    
                    <!-- Lastname 2 -->
                    <div class="form-control mt-3">
                        <label class="label">
                            <span class="label-text">Apellido materno</span>
                        </label>
                        <input type="text" name="lastname_2" placeholder="García" class="input input-bordered" required />
                    </div>
                    
                    <!-- Bio -->
                    <div class="form-control mt-3">
                        <label class="label">
                            <span class="label-text">Biografía breve</span>
                        </label>
                        <textarea name="bio" placeholder="Cuéntanos algo sobre ti..." class="textarea textarea-bordered h-20" maxlength="200"></textarea>
                        <label class="label">
                            <span class="label-text-alt">Máximo 200 caracteres</span>
                        </label>
                    </div>
                    
                    <div class="card-actions justify-center mt-6">
                        <button type="submit" class="btn btn-primary w-full">Registrarse</button>
                    </div>
                </form>
                <div class="divider"></div>
                <div class="text-center">
                    <p class="text-sm">¿Ya tienes cuenta? <a href="/login" class="link link-primary">Inicia sesión</a></p>
                </div>
            </div>
        </div>
    </div>
<script src="../path/to/flowbite/dist/flowbite.min.js"></script>
</body>
</html>
